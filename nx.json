{
	"$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/nx-schema.json",
	"installation": {
		"version": "22.2.7"
	},
	"targetDefaults": {
		"build": {
			"cache": true,
			"dependsOn": ["^build"]
		},
		"dev": {
			"cache": false
		},
		"lint": {
			"cache": true
		}
	},
	"namedInputs": {
		"default": ["{projectRoot}/**/*"],
		"production": ["default", "!{projectRoot}/**/*.spec.ts", "!{projectRoot}/**/*.test.ts"]
	},
	"defaultBase": "main"
}
